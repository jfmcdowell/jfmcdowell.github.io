{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useConst": "error",
        "noParameterAssign": "error",
        "useSelfClosingElements": "error",
        "noUnusedTemplateLiteral": "error",
        "useTemplate": "error",
        "useImportType": "error",
        "noNonNullAssertion": "error",
        "useEnumInitializers": "error",
        "useNumberNamespace": "error"
      },
      "correctness": {
        "noUndeclaredDependencies": "error"
      },
      "suspicious": {
        "noVar": "error"
      }
    }
  },
  "files": {
    "includes": [
      "src/**",
      "astro.config.ts",
      "biome.json",
      "tsconfig.json",
      ".github/**"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
